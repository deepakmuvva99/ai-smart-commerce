ENV=production
# Generate a secure 256-bit secret key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_secure_random_key_in_production

# Database Configuration
# Local SQLite fallback for dev
# DATABASE_URL=sqlite:///./sql_app.db
# Production PostgreSQL example (ensure host is locked down to 127.0.0.1 or VPC internal)
# DATABASE_URL=postgresql://smartcommerce_user:securepassword@127.0.0.1:5432/smartcommerce_db

# Security Settings
# Enforce HTTPS redirects (requires an SSL terminator like Nginx or AWS ALB in front, or direct certs)
ENFORCE_HTTPS=True
